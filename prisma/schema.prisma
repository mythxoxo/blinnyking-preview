generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  birthday  DateTime?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  guestName  String?
  guestEmail String?
  guestPhone String?
  items      Json
  total      Float
  discount   Float       @default(0)
  stripeId   String?
  status     OrderStatus @default(PENDING)
  location   String      @default("juri")
  createdAt  DateTime    @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  DONE
  CANCELLED
}
